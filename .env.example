# InvoGo — environment variables
#
# Copy this file to `.env` and fill in the values from your Supabase project:
#   cp .env.example .env
#
# Vite only exposes variables prefixed with VITE_ to the client bundle, so
# anything here ends up PUBLIC in the shipped frontend. Only put the
# anon/public key here — it is safe to expose and is protected by Row Level
# Security policies on the database.
#
# ⚠️  NEVER put the Supabase SERVICE ROLE key (or any other secret) in this
#     file or anywhere in client code. The service role key bypasses RLS and
#     must only ever live on a trusted server / serverless backend.

# Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=YOUR_SUPABASE_URL_HERE

# Supabase anon / public key — safe for the browser, RLS-protected
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
